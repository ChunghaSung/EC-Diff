;;; one another rule
(rule (=> (and
           (mayRf s1 s2 A p1)
           (mayRf s1 s4 A p1)
           (sameAtSec s2 s3 l1 p1)
           (postDom s3 s2 p1)
           (write s3 A p1)
           (diffAtSec s2 s4 l1 p1)
           (st s2 th1 p1)
           (st s4 th2 p1)
           (not (= th1 th2)))
       (mustNotOccurSeq s1 s2 s1 s4 p1)))


;; readFrom injective
(rule (=> (and 
           (mayRf s1 s3 A p1)
           (mayRf s2 s3 A p1)
           (not (= s1 s2)))
       (mustNotOccurSeq s1 s3 s2 s3 p1)))

;;; lock interleaving
(rule (=> (and
           (mayRf s1 s2 A p1)
           (mayRf s3 s4 B p1)
           (sameAtSec s1 s4 l1 p1)
           (sameAtSec s2 s3 l1 p1)
           (diffAtSec s1 s2 l1 p1))
       (mustNotOccurSeq s1 s2 s3 s4 p1)))

